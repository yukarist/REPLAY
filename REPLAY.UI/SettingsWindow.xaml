<Window x:Class="REPLAY.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Width="500"
        Height="500" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True" 
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="LowQuality">

    <Window.Resources>
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Border x:Name="templateRoot" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" SnapsToDevicePixels="true">
                <Grid HorizontalAlignment="Right" Width="30">
                    <Path x:Name="arrow" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#00F0FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="CyberComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#202646"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                            <Border x:Name="ComboBoxBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="toggleButton" Grid.ColumnSpan="2" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Template="{StaticResource ComboBoxToggleButton}"/>
                                    <ContentPresenter x:Name="contentPresenter" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="false"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                <Border x:Name="dropDownBorder" Background="#1A1A2E" BorderBrush="#5500F0FF" BorderThickness="1" CornerRadius="12" Margin="0,4,0,0" MinWidth="{Binding ActualWidth, ElementName=templateRoot}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0"/>
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBoxBorder" Property="BorderBrush" Value="#00F0FF"/>
                                <Setter TargetName="ComboBoxBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#202646"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#00F0FF"/>
                                <Setter TargetName="TextBoxBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#00F0FF"/>
                                <Setter TargetName="TextBoxBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#1A1A2E" BorderBrush="#202646" BorderThickness="1.2" CornerRadius="12" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#00F0FF"/>
                                <Setter TargetName="BtnBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0F132A"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.2" CornerRadius="12" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#FF6B6B"/>
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3D2A2A"/>
                                <Setter TargetName="BtnBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF6B6B" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="24"
                Margin="10"
                BorderThickness="1.5"
                ClipToBounds="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00F0FF" Offset="0"/>
                    <GradientStop Color="#A855F7" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0F2A" Offset="0"/>
                    <GradientStop Color="#11183A" Offset="0.5"/>
                    <GradientStop Color="#0A0F2A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="0">
                <Image Source="/Assets/bg.png" Opacity="0.25" Stretch="UniformToFill" Panel.ZIndex="-1"/>

                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False" PanningMode="None">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Margin="24">

                        <StackPanel x:Name="SettingsSection" Margin="0,0,0,24">

                            <Grid Margin="0,0,0,30">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- マイク感度 -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="マイク感度"
                   Foreground="#00F0FF"
                   FontSize="14"
                   Margin="0,12,0,0"/>

                                <Slider Grid.Row="0" Grid.Column="2"
                Minimum="0.005"
                Maximum="0.1"
                Value="{Binding MicThreshold}"
                TickFrequency="0.01"
                IsSnapToTickEnabled="True"
                Margin="0,16,0,0"/>

                                <TextBlock Grid.Row="0" Grid.Column="4"
                   Text="{Binding MicThreshold, StringFormat=F2}"
                   FontSize="14"
                   Foreground="#00F0FF"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"/>

                                <TextBlock Grid.Row="1" Grid.Column="2"
                   Grid.ColumnSpan="3"
                   Text="小さい：小声も拾う / 大きい：ノイズを減らす"
                   Foreground="#888"
                   FontSize="12"
                   Margin="0,6,0,10"/>

                                <!-- ノイズ除去 -->
                                <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="ノイズ除去"
                   Foreground="#00F0FF"
                   FontSize="14"
                   Margin="0,12,0,0"/>

                                <Slider Grid.Row="2" Grid.Column="2"
                Minimum="0"
                Maximum="0.1"
                Value="{Binding NoiseReduction}"
                TickFrequency="0.01"
                IsSnapToTickEnabled="True"
                Margin="0,16,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="4"
                   Text="{Binding NoiseReduction, StringFormat=F2}"
                   FontSize="14"
                   Foreground="#00F0FF"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"/>

                                <TextBlock Grid.Row="3" Grid.Column="2"
                   Grid.ColumnSpan="3"
                   Text="小さい：自然 / 大きい：強め（声も削れる）"
                   Foreground="#888"
                   FontSize="12"
                   Margin="0,6,0,10"/>

                                <!-- 無音確定 -->
                                <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="無音確定"
                   Foreground="#00F0FF"
                   FontSize="14"
                   Margin="0,12,0,0"/>

                                <Slider Grid.Row="4" Grid.Column="2"
                Minimum="500"
                Maximum="3000"
                Value="{Binding SilenceTimeout}"
                TickFrequency="100"
                IsSnapToTickEnabled="True"
                Margin="0,16,0,0"/>

                                <TextBlock Grid.Row="4" Grid.Column="4"
                   Text="{Binding SilenceTimeout, StringFormat={}{0} ms}"
                   FontSize="14"
                   Foreground="#00F0FF"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"/>

                                <TextBlock Grid.Row="5" Grid.Column="2"
                   Grid.ColumnSpan="3"
                   Text="短い：すぐ確定 / 長い：自然な会話"
                   Foreground="#888"
                   FontSize="12"
                   Margin="0,6,0,10"/>

                                <!-- 文章長 -->
                                <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="文章長"
                   Foreground="#00F0FF"
                   FontSize="14"
                   Margin="0,12,0,0"/>

                                <Slider Grid.Row="6" Grid.Column="2"
                Minimum="10"
                Maximum="60"
                Value="{Binding MaxSentenceLength}"
                TickFrequency="5"
                IsSnapToTickEnabled="True"
                Margin="0,16,0,0"/>

                                <TextBlock Grid.Row="6" Grid.Column="4"
                   Text="{Binding MaxSentenceLength}"
                   FontSize="14"
                   Foreground="#00F0FF"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"/>

                                <TextBlock Grid.Row="7" Grid.Column="2"
                   Grid.ColumnSpan="3"
                   Text="短い：細かく分割 / 長い：まとまる"
                   Foreground="#888"
                   FontSize="12"
                   Margin="0,6,0,10"/>

                                <!-- フィラー除去 -->
                                <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="フィラー除去"
                   Foreground="#00F0FF"
                   FontSize="14"
                   Margin="0,12,0,0"/>

                                <TextBlock Grid.Row="8" Grid.Column="4"
                   Text="{Binding FillerLabel}"
                  FontSize="14"
                   Foreground="#00F0FF"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"/>

                                <Slider Grid.Row="8" Grid.Column="2"
                Minimum="0"
                Maximum="2"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                Value="{Binding FillerLevel}"
                Margin="0,16,0,0"/>

                                <TextBlock Grid.Row="9" Grid.Column="2"
                   Text="OFF：そのまま / 弱：自然 / 強：しっかり除去"
                   Foreground="#888"
                   FontSize="12"
                   Margin="0,6,0,0"/>

                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="CsvSection" Margin="0,0,0,24">
                            <TextBlock Text="データ管理・出力" Foreground="#00F0FF" Margin="4,0,0,8" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <Grid Margin="0,12,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="ログ保管期間" Foreground="#00F0FF" FontSize="14" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding LogKeepDays}" Style="{StaticResource CyberTextBoxStyle}" Height="40" ToolTip="この日数より古い過去ログは、アプリ起動時に自動で削除されます"/>
                                <TextBlock Grid.Column="4" Text="日間" Foreground="#00F0FF" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="※未設定、または 0 を指定すると初期値（7日間）になります" Foreground="#888" FontSize="12" Margin="99,-8,0,20"/>

                            <Button Content="保管設定を保存" Height="40" Margin="0,0,0,24" BorderBrush="#00F0FF" Style="{StaticResource NeonButtonStyle}" Click="Save_Click"/>

                            <Button Content="お気に入りをCSV出力" Height="40" Style="{StaticResource NeonButtonStyle}" Command="{Binding ExportFavoritesCommand}"/>
                            <Button Content="全てのログをCSV出力" Height="40" Margin="0,20,0,0" Style="{StaticResource NeonButtonStyle}" Command="{Binding ExportAllCommand}"/>
                            <Button Content="選択した日付のログをCSV出力" Height="40" Margin="0,20,0,0" Style="{StaticResource NeonButtonStyle}" Command="{Binding ExportSelectedDateCommand}"/>
                        </StackPanel>

                        <StackPanel x:Name="AiSection" Margin="0,0,0,28">
                            <Grid x:Name="AiSettingsSection" Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIモード" Foreground="#00F0FF" FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </TextBlock.Effect></TextBlock>
                                <ComboBox Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
      Height="40"
      SelectedIndex="{Binding AiModeIndex}"
      Style="{StaticResource CyberComboBoxStyle}"
      VerticalContentAlignment="Center">

                                    <ComboBoxItem Content="OFF"/>
                                    <ComboBoxItem Content="軽い：リアルタイム表示向け"/>
                                    <ComboBoxItem Content="高精度：要約・文章向け"/>
                                </ComboBox>
                                <TextBlock
Grid.Row="1"
Grid.Column="2"
Grid.ColumnSpan="3"
Text="軽い：リアルタイム / 高精度：少し遅い"
Foreground="#888"
FontSize="10"
Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="APIキー" Foreground="#00F0FF" FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </TextBlock.Effect></TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="2" Height="40" Text="{Binding ApiKey}" Style="{StaticResource CyberTextBoxStyle}" ToolTip="Gemini用APIキー（要約で使用）"/>
                                <Button Grid.Row="2" Grid.Column="4" Content="保存" Height="40" BorderBrush="#00F0FF" Style="{StaticResource NeonButtonStyle}" Click="Save_Click"/>
                            </Grid>
                            <TextBlock Text="AI要約" Foreground="#A855F7" Margin="4,0,0,8" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#A855F7" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                </TextBlock.Effect></TextBlock>
                            <Button Content="AIで要約" Height="40" Style="{StaticResource NeonButtonStyle}" Command="{Binding GenerateSummaryCommand}"/>
                            <Button Content="AI要約をテキスト出力" Height="40" Margin="0,20,0,0" Style="{StaticResource NeonButtonStyle}" Command="{Binding ExportSummaryCommand}"/>
                        </StackPanel>
                        
                        <TextBlock Text="{Binding SummaryStatusText}" 
           Foreground="#00F0FF" 
           FontSize="14" 
           HorizontalAlignment="Center" 
           VerticalAlignment="Center"
           Margin="10"/>
                        <Button Content="閉じる" Height="40" Width="160" HorizontalAlignment="Center" Style="{StaticResource CloseButtonStyle}" Click="Close_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="Toast"
        Background="#CC0090AA"
        CornerRadius="10"
        Padding="16,10"
        HorizontalAlignment="Center"
        VerticalAlignment="Bottom"
        Margin="0,0,0,30"
        Opacity="0"
        IsHitTestVisible="False">

            <Border.Effect>
                <DropShadowEffect Color="#00F0FF" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>

            <TextBlock x:Name="ToastText"
               Text="設定を保存しました"
               Foreground="White"
               FontSize="14"
               FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>