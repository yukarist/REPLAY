<Window x:Class="REPLAY.UI.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI要約"
        Width="500"
        Height="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#1A1A2E" BorderBrush="#202646" BorderThickness="1.2" CornerRadius="12" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#00F0FF"/>
                                <Setter TargetName="BtnBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#202646"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#00F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0F132A"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.2" CornerRadius="12" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#FF6B6B"/>
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3D2A2A"/>
                                <Setter TargetName="BtnBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF6B6B" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="24" Margin="10" BorderThickness="1.5" ClipToBounds="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00F0FF" Offset="0"/>
                    <GradientStop Color="#A855F7" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0F2A" Offset="0"/>
                    <GradientStop Color="#11183A" Offset="0.5"/>
                    <GradientStop Color="#0A0F2A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="24">
                <Image Source="/Assets/bg.png" Opacity="0.25" Stretch="UniformToFill" Panel.ZIndex="-1"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="AI要約" Foreground="#A855F7" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Button Grid.Row="1" Content="📋 コピー" Height="40" Width="120" HorizontalAlignment="Right" Style="{StaticResource NeonButtonStyle}" Click="Copy_Click"/>

                    <TextBox Grid.Row="2" x:Name="SummaryText" Margin="0,10,0,0" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Style="{StaticResource CyberTextBoxStyle}"/>

                    <Button Grid.Row="3" Content="閉じる" Height="40" Width="160" Margin="0,20,0,0" HorizontalAlignment="Center" Style="{StaticResource CloseButtonStyle}" Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="Toast" Background="#CC00F0FF" CornerRadius="10" Padding="16,10" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" Opacity="0" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="#00F0FF" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>
            <TextBlock x:Name="ToastText" Text="コピーしました" Foreground="Black" FontSize="14" FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>