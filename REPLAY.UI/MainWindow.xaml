<Window x:Class="REPLAY.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:REPLAY.UI.Behaviors"
        Title="RE:PLAY"
        Width="800"
        Height="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Icon="Assets/アイコン.ico"
        SnapsToDevicePixels="True" 
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="LowQuality">

    <Window.Resources>
        <local:HighlightConverter x:Key="HighlightConverter"/>
        <local:StarConverter x:Key="StarConverter"/>

        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F132A"/>
            <Setter Property="Foreground" Value="#00F0FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding Foreground}" 
                                BorderThickness="1" 
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#00F0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D244D"/>
                                <Setter TargetName="ButtonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="18" ShadowDepth="0" Opacity="0.85"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#080A18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle"
                                CornerRadius="3"
                                Background="#00F0FF"
                                Opacity="0.5"
                                SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#80F8FF"/>
                                <Setter TargetName="rectangle" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#00F0FF"/>
                                <Setter TargetName="rectangle" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="2"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Border CornerRadius="1" Background="#0F132A" Opacity="0.6"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Background="Transparent" BorderBrush="Transparent" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Background="Transparent" BorderBrush="Transparent" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CyberScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="Transparent">

        <Border CornerRadius="24"
                Margin="10"
                BorderThickness="1.5"
                ClipToBounds="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00F0FF" Offset="0"/>
                    <GradientStop Color="#A855F7" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="#4F46E5" Opacity="0.5"/>
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0F2A" Offset="0"/>
                    <GradientStop Color="#11183A" Offset="0.5"/>
                    <GradientStop Color="#0A0F2A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Background="Transparent">

                <Image Source="/Assets/bg.png"
                       Opacity="0.25"
                       Stretch="Fill"
                       Panel.ZIndex="-1"
                       IsHitTestVisible="False"/>

                <Rectangle VerticalAlignment="Top"
                           Height="200"
                           Opacity="0.2"
                           IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0" Center="0.5,0" RadiusX="1" RadiusY="1">
                            <GradientStop Color="#00F0FF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Rectangle VerticalAlignment="Bottom"
                           Height="300"
                           Opacity="0.2"
                           IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="1" RadiusY="1">
                            <GradientStop Color="#A855F7" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Grid Margin="20" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="16"
                            Margin="0,0,0,12"
                            Background="#08FFFFFF"
                            Padding="12"
                            HorizontalAlignment="Stretch"
                            MouseLeftButtonDown="Header_MouseLeftButtonDown"
                            Cursor="SizeAll">

                        <Grid Height="80" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Border Width="64" Height="64" CornerRadius="14" Background="#10FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" Padding="6" Margin="0,0,12,0">
                                    <Grid>
                                        <Image Source="Assets/UI.png" Stretch="Uniform"/>
                                        <Grid.Effect>
                                            <DropShadowEffect Color="#00F0FF" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                                        </Grid.Effect>
                                    </Grid>
                                </Border>

                                <TextBlock Text="R E : P L A Y" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00F0FF" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>

                            <Button Grid.Column="2" Content="Start" Width="110" Height="42" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#00F0FF" Command="{Binding StartCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Border x:Name="Border" CornerRadius="10" Background="#0DFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.FontWeight="Bold" TextElement.FontSize="16" TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.ActiveButton, RelativeSource={RelativeSource AncestorType=Window}}" Value="Start">
                                                            <Setter TargetName="Border" Property="Background" Value="#0F132A"/>
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#00F0FF"/>
                                                            <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                                                            <Setter TargetName="Border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#00F0FF" BlurRadius="35" ShadowDepth="0" Opacity="1"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="3" Content="Stop" Width="110" Height="42" VerticalAlignment="Center" Foreground="#FF5555" Command="{Binding StopCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Border x:Name="ShadowBorder" CornerRadius="10" Background="Transparent"/>
                                                        <Border x:Name="Border" CornerRadius="10" Background="#0DFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.FontWeight="Bold" TextElement.FontSize="16" TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#FF6B6B"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding DataContext.ActiveButton, RelativeSource={RelativeSource AncestorType=Window}}" Value="Stop">
                                                            <Setter TargetName="Border" Property="Background" Value="#0F132A"/>
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#FF0000"/>
                                                            <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                                                            <Setter TargetName="Border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#FF0000" BlurRadius="40" ShadowDepth="0" Opacity="1"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="4"
                                    Content="✕"
                                    Width="40"
                                    Height="40"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="#FF5555"
                                    Click="Exit_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Border"
                                                            CornerRadius="10"
                                                            Background="#0DFFFFFF"
                                                            BorderBrush="#15FFFFFF"
                                                            BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#FF0000"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,16,0,16" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Height="50" CornerRadius="12" Background="#0F132A" BorderBrush="#202646" BorderThickness="1.2" Padding="14,0" VerticalAlignment="Center">
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0" CaretBrush="White" VerticalContentAlignment="Center" FontSize="14">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <TextBlock x:Name="PlaceholderTextBlock" Text="検索ワードを入力..." Foreground="#44FFFFFF" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False"/>
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="PlaceholderTextBlock" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>

                        <ComboBox Grid.Column="1" Width="280" Height="50" Margin="12,0,0,0" ItemsSource="{Binding Devices}" SelectedIndex="{Binding SelectedDeviceIndex}" VerticalAlignment="Center" Foreground="White">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="ItemBorder" Background="#0F132A" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,2">
                                                    <ContentPresenter ContentSource="DataContext"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#226366F1"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#444F46E5"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#00F0FF"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.Template>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <ToggleButton x:Name="ToggleButton" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border BorderBrush="#202646" BorderThickness="1.2" CornerRadius="12" Background="#0F132A">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                            <Grid>
                                                <TextBlock Text="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" Foreground="White" Margin="14,0,28,0" VerticalAlignment="Center" FontSize="14"/>
                                                <TextBlock Text="▼" Foreground="#A5B4FC" HorizontalAlignment="Right" Margin="0,0,14,0" VerticalAlignment="Center" FontSize="10"/>
                                            </Grid>
                                        </ToggleButton>
                                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Slide" StaysOpen="False">
                                            <Border Width="{TemplateBinding ActualWidth}" Background="#0F132A" BorderBrush="#202646" BorderThickness="1" CornerRadius="12" Margin="0,4,0,0" Padding="2">
                                                <ScrollViewer MaxHeight="200" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Hidden">
                                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </ControlTemplate>
                            </ComboBox.Template>
                        </ComboBox>

                        <ToggleButton Grid.Column="2"
              Width="50"
              Height="50"
              Margin="12,0,0,0"
              Background="#0F132A"
              BorderBrush="{x:Null}"
              Cursor="Hand"
              IsChecked="{Binding ShowFavoritesOnly, Mode=TwoWay}"
              VerticalAlignment="Center">

                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Border"
                    CornerRadius="12"
                    BorderThickness="1.2"
                    BorderBrush="#202646"
                    Background="#0F132A">

                                        <TextBlock x:Name="StarIcon"
                           Text="☆"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#A5B4FC"/>
                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <!-- ON（お気に入りのみ） -->
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#FFD700"/>
                                            <Setter TargetName="StarIcon" Property="Text" Value="★"/>
                                            <Setter TargetName="StarIcon" Property="Foreground" Value="#FFD700"/>
                                        </Trigger>

                                        <!-- ホバー -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#00F0FF"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>

                    <Border Grid.Row="3" Margin="0,8,0,8" Height="60" CornerRadius="30"
        Background="#1A1A2E" BorderBrush="#33FFFFFF" BorderThickness="1">

                        <Border.Resources>
                            <Style TargetType="Rectangle">
                                <Setter Property="Fill">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00F0FF" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="0.5"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RadiusX" Value="3"/>
                                <Setter Property="RadiusY" Value="3"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Border.Resources>

                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Rectangle x:Name="Bar1" Grid.Column="0" Width="14"/>
                            <Rectangle x:Name="Bar2" Grid.Column="1" Width="14"/>
                            <Rectangle x:Name="Bar3" Grid.Column="2" Width="14"/>
                            <Rectangle x:Name="Bar4" Grid.Column="3" Width="16"/>
                            <Rectangle x:Name="Bar5" Grid.Column="4" Width="18"/>
                            <Rectangle x:Name="Bar6" Grid.Column="5" Width="18"/>
                            <Rectangle x:Name="Bar7" Grid.Column="6" Width="16"/>
                            <Rectangle x:Name="Bar8" Grid.Column="7" Width="14"/>
                            <Rectangle x:Name="Bar9" Grid.Column="8" Width="14"/>
                            <Rectangle x:Name="Bar10" Grid.Column="9" Width="14"/>

                        </Grid>
                    </Border>

                    <Border Grid.Row="4" BorderThickness="1.2" CornerRadius="16" Background="Transparent" Padding="14">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00F0FF" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="0.7"/>
                                <GradientStop Color="#A855F7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.25" Color="#A855F7"/>
                        </Border.Effect>

                        <Grid Background="Transparent">
                            <Border CornerRadius="14" Margin="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#05FFFFFF" Offset="0"/>
                                        <GradientStop Color="#01FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Grid Background="Transparent">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- 0 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- 1 日付 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- 2 LiveText ←追加🔥 -->
                                    <RowDefinition Height="*"/>
                                    <!-- 3 ログ -->
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="4,0,0,10">
                                   
                                </Grid>


                                <ListBox Grid.Row="1"
         ItemsSource="{Binding Dates}"
         SelectedItem="{Binding SelectedDate}"
         Height="65"
         Margin="0,0,0,12"
         Background="#0AFFFFFF"
         BorderBrush="#202646"
         BorderThickness="1"
         Foreground="White"
         ScrollViewer.HorizontalScrollBarVisibility="Auto"
         ScrollViewer.VerticalScrollBarVisibility="Disabled">

                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="#15FFFFFF"/>
                                            <Setter Property="Foreground" Value="#A5B4FC"/>
                                            <Setter Property="Margin" Value="4,2"/>
                                            <Setter Property="Padding" Value="14,6"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="DateBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DateBorder" Property="Background" Value="#2200F0FF"/>
                                                                <Setter Property="Foreground" Value="#00F0FF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="DateBorder" Property="Background" Value="#0F132A"/>
                                                                <Setter TargetName="DateBorder" Property="BorderBrush" Value="#00F0FF"/>
                                                                <Setter TargetName="DateBorder" Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Foreground" Value="#00F0FF"/>
                                                                <Setter TargetName="DateBorder" Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#00F0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- 🔥 ここ追加（ListBoxの上） -->
                                <Border Grid.Row="2"
        Background="#1400F0FF"
        CornerRadius="6"
        Padding="8,4"
        Margin="0,4,0,8">

                                    <!-- 🔥 空のとき非表示 -->
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LiveTextDisplay}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="{Binding LiveTextDisplay}"
               Foreground="#DDFFFFFF"
               FontStyle="Italic"
               FontSize="15"
               FontWeight="SemiBold"
               TextWrapping="Wrap"
               MaxHeight="48"
               IsHitTestVisible="False"/>
                                    
                                </Border>

                                <Button Click="ReturnToCurrent_Click"
        Style="{StaticResource NeonButtonStyle}"
        Width="160" 
        Height="32"
        HorizontalContentAlignment="Center" Margin="0,4" 
        HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🔄" Foreground="#00F0FF" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="現在のログに戻る" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <ListBox Grid.Row="3" Margin="0,0,0,10" x:Name="LogListBox" ItemsSource="{Binding DateFilteredLogs}" Background="Transparent" BorderThickness="0" Foreground="#EAEAFF" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                    <Setter Property="Foreground" Value="#888"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <i:Interaction.Behaviors>
                                        <local:AutoScrollBehavior/>
                                    </i:Interaction.Behaviors>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,10" BorderBrush="#1B2040" BorderThickness="0,0,0,1" Background="Transparent">
                                                <Grid HorizontalAlignment="Stretch" Background="Transparent">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat=HH:mm:ss}" Foreground="#55FFFFFF" VerticalAlignment="Center" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CorrectedText}" TextWrapping="Wrap" Margin="8,0" FontSize="15" LineHeight="20" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

                                                    <StackPanel Grid.Column="2" Width="74" HorizontalAlignment="Right" VerticalAlignment="Stretch" Orientation="Horizontal" Background="Transparent">
                                                        <Button Width="28" Margin="0,0,8,0" VerticalAlignment="Stretch" Background="Transparent" BorderBrush="{x:Null}" Cursor="Hand" Command="{Binding DataContext.DeleteLogCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Border" CornerRadius="6" BorderThickness="1" BorderBrush="#FF5555" Background="Transparent" VerticalAlignment="Stretch">
                                                                        <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF5555" FontSize="12" FontWeight="Bold"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Border" Property="Background" Value="#22FF5555"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Button Width="28" VerticalAlignment="Stretch" Background="Transparent" BorderBrush="{x:Null}" Cursor="Hand" Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="BtnBorder" CornerRadius="6" BorderBrush="#555" BorderThickness="1" Background="Transparent" Cursor="Hand" VerticalAlignment="Stretch">
                                                                        <TextBlock x:Name="StarIcon" Text="★" FontSize="14" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter TargetName="StarIcon" Property="Foreground" Value="#FFD700"/>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="StarIcon" Property="Foreground" Value="#FFF176"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Grid Grid.Row="4" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="1" BorderBrush="#6366F1" BorderThickness="1,1,0,0" CornerRadius="16,0,0,0" Background="#CC090C22" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12,0,-14,-14" Padding="14,10">
                                        <Grid HorizontalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Width="72" Height="60" Click="OpenSettings_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Border CornerRadius="12" BorderBrush="#00F0FF" BorderThickness="1" Background="#0C1530">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                                </Border.Effect>
                                                            </Border>
                                                            <Border x:Name="BtnBorder" CornerRadius="12" BorderBrush="#00F0FF" BorderThickness="1" Background="Transparent" Cursor="Hand">
                                                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Text="⚙" FontSize="20" Foreground="#00F0FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Row="1" Text="設定" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#1100F0FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Grid.Column="2"
        Width="72"
        Height="60"
        Click="OpenCsv_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Border CornerRadius="12" BorderBrush="#00F0FF" BorderThickness="1" Background="#0C1530">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                                </Border.Effect>
                                                            </Border>
                                                            <Border x:Name="BtnBorder" CornerRadius="12" BorderBrush="#00F0FF" BorderThickness="1" Background="Transparent" Cursor="Hand">
                                                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Text="📋" FontSize="18" Foreground="#00F0FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Row="1" Text="データ管理" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#1100F0FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Grid.Column="4" Width="72" Height="60" Click="OpenAi_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Border CornerRadius="12" BorderBrush="#C084FC" BorderThickness="1" Background="#1B1032">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#A855F7" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                                </Border.Effect>
                                                            </Border>
                                                            <Border x:Name="BtnBorder" CornerRadius="12" BorderBrush="#C084FC" BorderThickness="1" Background="Transparent" Cursor="Hand">
                                                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Text="✨" FontSize="18" Foreground="#E9D5FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Row="1" Text="AI" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#11A855F7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>